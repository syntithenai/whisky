<!-- AGE VERIFICATION - Paste this ANYWHERE in your HTML (works across all pages) -->
<div id="ageVerificationSystem">
  <style>
    /* Age Verification Styles - Self Contained */
    #ageVerificationSystem .age-gate {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 99999;
      display: none;
      align-items: center;
      justify-content: center;
      font-family: 'Raleway', sans-serif;
      opacity: 0;
      transition: opacity 0.5s ease;
    }
    
    #ageVerificationSystem .age-gate.active {
      display: flex;
    }
    
    #ageVerificationSystem .age-gate.visible {
      opacity: 1;
    }
    
    #ageVerificationSystem .age-gate__overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(10px);
    }
    
    #ageVerificationSystem .age-gate__modal {
      position: relative;
      width: 90%;
      max-width: 500px;
      max-height: 85vh;
      background: #1a1a1a;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      transform: scale(0.9);
      transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      z-index: 1;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    
    #ageVerificationSystem .age-gate.visible .age-gate__modal {
      transform: scale(1);
    }
    
    #ageVerificationSystem .age-gate__scroll-wrapper {
      overflow-y: auto;
      overflow-x: hidden;
      flex: 1;
      scrollbar-width: thin;
      scrollbar-color: #333 #1a1a1a;
    }
    
    #ageVerificationSystem .age-gate__scroll-wrapper::-webkit-scrollbar {
      width: 6px;
    }
    
    #ageVerificationSystem .age-gate__scroll-wrapper::-webkit-scrollbar-track {
      background: #1a1a1a;
    }
    
    #ageVerificationSystem .age-gate__scroll-wrapper::-webkit-scrollbar-thumb {
      background: #333;
      border-radius: 3px;
    }
    
    #ageVerificationSystem .age-gate__scroll-wrapper::-webkit-scrollbar-thumb:hover {
      background: #444;
    }
    
    #ageVerificationSystem .age-gate__content {
      padding: 3rem 2rem;
    }
    
    #ageVerificationSystem .age-gate__logo {
      text-align: center;
      margin-bottom: 2rem;
    }
    
    #ageVerificationSystem .age-gate__logo img {
      height: 40px;
      width: auto;
    }
    
    #ageVerificationSystem .age-gate__title {
      font-family: 'Cinzel', serif;
      font-size: 2rem;
      font-weight: 700;
      color: #fff;
      text-align: center;
      margin: 0 0 0.5rem;
      letter-spacing: 2px;
    }
    
    #ageVerificationSystem .age-gate__subtitle {
      font-size: 1rem;
      color: #999;
      text-align: center;
      margin: 0 0 2rem;
      line-height: 1.6;
    }
    
    #ageVerificationSystem .age-gate__form {
      margin-bottom: 2rem;
    }

    /* ── AGE CONFIRM — card-style checkbox ──────────────────────── */
    #ageVerificationSystem .age-gate__confirm {
      margin-bottom: 1.25rem;
    }

    /* Hide the native input but keep it accessible */
    #ageVerificationSystem #ageGateConfirm {
      position: absolute;
      opacity: 0;
      width: 1px;
      height: 1px;
      pointer-events: none;
    }

    #ageVerificationSystem .age-confirm-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      border: 1px solid #333;
      border-radius: 8px;
      background: #222;
      cursor: pointer;
      transition: border-color 0.25s ease, background 0.25s ease;
      -webkit-user-select: none;
      user-select: none;
    }

    #ageVerificationSystem .age-confirm-card:hover {
      border-color: #555;
      background: #272727;
    }

    #ageVerificationSystem #ageGateConfirm:checked + .age-confirm-card {
      border-color: #fff;
      background: #242424;
    }

    /* The custom box */
    #ageVerificationSystem .age-confirm-box {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      border: 1.5px solid #555;
      border-radius: 5px;
      background: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.25s ease, background 0.25s ease;
    }

    #ageVerificationSystem #ageGateConfirm:checked + .age-confirm-card .age-confirm-box {
      border-color: #fff;
      background: #fff;
    }

    /* SVG tick */
    #ageVerificationSystem .age-confirm-box svg {
      width: 13px;
      height: 10px;
      stroke: #000;
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.18s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    #ageVerificationSystem #ageGateConfirm:checked + .age-confirm-card .age-confirm-box svg {
      opacity: 1;
      transform: scale(1);
    }

    #ageVerificationSystem .age-confirm-text {
      font-size: 0.95rem;
      color: #999;
      line-height: 1.4;
      transition: color 0.25s ease;
    }

    #ageVerificationSystem #ageGateConfirm:checked + .age-confirm-card .age-confirm-text {
      color: #fff;
    }

    /* ── ERROR ──────────────────────────────────────────────────── */
    #ageVerificationSystem .age-gate__error {
      min-height: 20px;
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 6px;
      color: #fff;
      font-size: 0.85rem;
      text-align: center;
      display: none;
      animation: shake 0.4s ease;
      line-height: 1.5;
    }
    
    #ageVerificationSystem .age-gate__error.show {
      display: block;
    }

    /* ── REMEMBER ME — pill toggle ──────────────────────────────── */
    #ageVerificationSystem .age-gate__checkbox {
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Hide native checkbox */
    #ageVerificationSystem #ageGateRemember {
      position: absolute;
      opacity: 0;
      width: 1px;
      height: 1px;
      pointer-events: none;
    }

    #ageVerificationSystem .remember-label {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      cursor: pointer;
      font-size: 0.85rem;
      color: #777;
      transition: color 0.25s ease;
      -webkit-user-select: none;
      user-select: none;
    }

    #ageVerificationSystem .remember-label:hover {
      color: #aaa;
    }

    #ageVerificationSystem #ageGateRemember:checked + .remember-label {
      color: #bbb;
    }

    /* pill track */
    #ageVerificationSystem .remember-track {
      flex-shrink: 0;
      width: 38px;
      height: 22px;
      border-radius: 999px;
      background: #2e2e2e;
      border: 1px solid #444;
      position: relative;
      transition: background 0.25s ease, border-color 0.25s ease;
    }

    #ageVerificationSystem #ageGateRemember:checked + .remember-label .remember-track {
      background: #fff;
      border-color: #fff;
    }

    /* pill thumb */
    #ageVerificationSystem .remember-thumb {
      position: absolute;
      top: 3px;
      left: 3px;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #555;
      transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s ease;
    }

    #ageVerificationSystem #ageGateRemember:checked + .remember-label .remember-thumb {
      transform: translateX(16px);
      background: #111;
    }

    /* ── BUTTONS ────────────────────────────────────────────────── */
    #ageVerificationSystem .age-gate__button,
    #ageVerificationSystem .age-gate__exit {
      width: 100%;
      padding: 1rem;
      font-family: 'Raleway', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    
    #ageVerificationSystem .age-gate__button {
      background: #fff;
      color: #000;
      margin-bottom: 0.75rem;
    }
    
    #ageVerificationSystem .age-gate__button:hover {
      background: #f0f0f0;
      transform: translateY(-2px);
      box-shadow: 0 5px 20px rgba(255, 255, 255, 0.3);
    }
    
    #ageVerificationSystem .age-gate__button:active {
      transform: translateY(0);
    }
    
    #ageVerificationSystem .age-gate__exit {
      background: transparent;
      color: #999;
      border: 1px solid #333;
    }
    
    #ageVerificationSystem .age-gate__exit:hover {
      border-color: #666;
      color: #ccc;
      background: rgba(255, 255, 255, 0.05);
    }

    /* ── FOOTER ─────────────────────────────────────────────────── */
    #ageVerificationSystem .age-gate__footer {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid #333;
    }
    
    #ageVerificationSystem .age-gate__footer p {
      font-size: 0.75rem;
      color: #666;
      text-align: center;
      line-height: 1.6;
      margin: 0 0 1rem;
    }
    
    #ageVerificationSystem .age-gate__warning {
      color: #999 !important;
      font-size: 0.7rem !important;
    }
    
    #ageVerificationSystem .age-gate__warning strong {
      color: #fff;
    }
    
    /* ── ANIMATIONS ─────────────────────────────────────────────── */
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }
    
    /* ── MOBILE ─────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      #ageVerificationSystem .age-gate__modal {
        width: 95%;
        max-height: 90vh;
      }
      
      #ageVerificationSystem .age-gate__content {
        padding: 2rem 1.5rem;
      }
      
      #ageVerificationSystem .age-gate__logo img {
        height: 30px;
      }
      
      #ageVerificationSystem .age-gate__title {
        font-size: 1.5rem;
        letter-spacing: 1px;
      }
      
      #ageVerificationSystem .age-gate__subtitle {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
      }

      #ageVerificationSystem .age-confirm-card {
        padding: 0.85rem 1rem;
        gap: 0.85rem;
      }

      #ageVerificationSystem .age-confirm-box {
        width: 22px;
        height: 22px;
      }

      #ageVerificationSystem .age-confirm-text {
        font-size: 0.9rem;
      }
      
      #ageVerificationSystem .age-gate__error {
        padding: 0.65rem 0.85rem;
        font-size: 0.8rem;
      }

      #ageVerificationSystem .remember-label {
        font-size: 0.82rem;
      }
      
      #ageVerificationSystem .age-gate__button,
      #ageVerificationSystem .age-gate__exit {
        padding: 0.85rem;
        font-size: 0.9rem;
        letter-spacing: 1px;
      }
      
      #ageVerificationSystem .age-gate__footer {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
      }
      
      #ageVerificationSystem .age-gate__footer p {
        font-size: 0.68rem;
      }
      
      #ageVerificationSystem .age-gate__warning {
        font-size: 0.65rem !important;
      }
    }
    
    @media (max-width: 380px) {
      #ageVerificationSystem .age-gate__content {
        padding: 1.5rem 1rem;
      }
      
      #ageVerificationSystem .age-gate__title {
        font-size: 1.3rem;
      }

      #ageVerificationSystem .age-confirm-card {
        padding: 0.75rem 0.85rem;
        gap: 0.75rem;
      }

      #ageVerificationSystem .age-confirm-text {
        font-size: 0.85rem;
      }
    }
    
    @media (max-width: 768px) and (orientation: landscape) {
      #ageVerificationSystem .age-gate__modal {
        max-height: 95vh;
      }
      
      #ageVerificationSystem .age-gate__content {
        padding: 1.5rem 2rem;
      }
      
      #ageVerificationSystem .age-gate__logo {
        margin-bottom: 1rem;
      }
      
      #ageVerificationSystem .age-gate__subtitle {
        margin-bottom: 1rem;
      }
      
      #ageVerificationSystem .age-gate__footer {
        margin-top: 1rem;
        padding-top: 1rem;
      }
    }
    
    body.age-gate-active {
      overflow: hidden !important;
      height: 100vh;
      position: fixed;
      width: 100%;
    }
  </style>

  <!-- Modal HTML -->
  <div class="age-gate" id="ageGate">
    <div class="age-gate__overlay"></div>
    <div class="age-gate__modal">
      <div class="age-gate__scroll-wrapper">
        <div class="age-gate__content">
          <div class="age-gate__logo">
            <img src="img/general/logo-white.svg" alt="Adelaide Distillery" onerror="this.style.display='none'"/>
          </div>
          
          <h2 class="age-gate__title">Welcome</h2>
          <p class="age-gate__subtitle">You must be 18 years or older to enter this site</p>
          
          <div class="age-gate__form">

            <!-- Age confirmation — card-style custom checkbox -->
            <div class="age-gate__confirm">
              <input type="checkbox" id="ageGateConfirm">
              <label class="age-confirm-card" for="ageGateConfirm">
                <span class="age-confirm-box">
                  <svg viewBox="0 0 13 10" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="1.5 5 5 8.5 11.5 1.5"/>
                  </svg>
                </span>
                <span class="age-confirm-text">I confirm that I am 18 years of age or older</span>
              </label>
            </div>

            <div class="age-gate__error" id="ageGateError"></div>
            
            <!-- Remember me — pill toggle -->
            <div class="age-gate__checkbox">
              <input type="checkbox" id="ageGateRemember" checked>
              <label class="remember-label" for="ageGateRemember">
                <span class="remember-track">
                  <span class="remember-thumb"></span>
                </span>
                Remember me for 30 days
              </label>
            </div>
            
            <button type="button" class="age-gate__button" id="ageGateVerifyBtn">
              <span>Enter Site</span>
            </button>
            
            <button type="button" class="age-gate__exit" id="ageGateExitBtn">
              <span>I'm Under 18</span>
            </button>
          </div>
          
          <div class="age-gate__footer">
            <p>By entering this site, you agree to our Terms of Service and acknowledge our Privacy Policy.</p>
            <p class="age-gate__warning">
              <strong>WARNING:</strong> Under the Liquor Control Act 1988, it is an offence to sell or supply liquor to a person under the age of 18 years on licensed or regulated premises.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      'use strict';
      
      const AgeGate = {
        cookieName: 'adelaideDistilleryAgeVerified',
        cookieDays: 30,
        minAge: 18,
        
        init() {
          if (this.checkCookie()) return;
          this.waitForPreloader();
        },
        
        waitForPreloader() {
          const preloader = document.getElementById('js-preloader');
          
          if (preloader) {
            const checkPreloader = setInterval(() => {
              const preloaderStyle = window.getComputedStyle(preloader);
              const isHidden = preloaderStyle.display === 'none' || 
                              preloaderStyle.opacity === '0' || 
                              preloaderStyle.visibility === 'hidden';
              
              if (isHidden) {
                clearInterval(checkPreloader);
                setTimeout(() => {
                  this.showModal();
                  this.bindEvents();
                }, 300);
              }
            }, 100);
            
            setTimeout(() => {
              clearInterval(checkPreloader);
              if (!document.getElementById('ageGate').classList.contains('active')) {
                this.showModal();
                this.bindEvents();
              }
            }, 5000);
          } else {
            this.showModal();
            this.bindEvents();
          }
        },
        
        showModal() {
          const modal = document.getElementById('ageGate');
          if (modal) {
            document.body.classList.add('age-gate-active');
            modal.classList.add('active');
            setTimeout(() => modal.classList.add('visible'), 50);
          }
        },
        
        hideModal() {
          const modal = document.getElementById('ageGate');
          if (modal) {
            modal.classList.remove('visible');
            setTimeout(() => {
              modal.classList.remove('active');
              document.body.classList.remove('age-gate-active');
            }, 500);
          }
        },
        
        bindEvents() {
          const verifyBtn = document.getElementById('ageGateVerifyBtn');
          const exitBtn   = document.getElementById('ageGateExitBtn');
          if (verifyBtn) verifyBtn.addEventListener('click', () => this.verifyAge());
          if (exitBtn)   exitBtn.addEventListener('click',   () => this.exitSite());
        },
        
        verifyAge() {
          const confirmed = document.getElementById('ageGateConfirm').checked;
          const remember  = document.getElementById('ageGateRemember').checked;
          
          if (!confirmed) {
            this.showError('Please confirm that you are 18 years of age or older');
            return;
          }
          
          this.setCookie(remember ? this.cookieDays : 0);
          this.hideModal();
        },
        
        showError(message) {
          const errorDiv = document.getElementById('ageGateError');
          if (errorDiv) {
            errorDiv.textContent = message;
            errorDiv.classList.add('show');
            setTimeout(() => errorDiv.classList.remove('show'), 5000);
          }
        },
        
        exitSite() {
          window.location.href = 'https://www.google.com';
        },
        
        setCookie(days) {
          const expires = days === 0 ? '' : '; expires=' + new Date(Date.now() + days * 864e5).toUTCString();
          document.cookie = this.cookieName + '=true' + expires + '; path=/; SameSite=Strict';
        },
        
        checkCookie() {
          return document.cookie.split('; ').find(row => row.startsWith(this.cookieName + '=')) !== undefined;
        }
      };
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => AgeGate.init());
      } else {
        AgeGate.init();
      }
    })();
  </script>
</div>
    <div id="shopify-cart-widget"></div>

<style>
/* Luxury Minimal CTA Button */
.glass-cta-button {
  position: relative;
  padding: 0.875rem 2rem;
  background: transparent;
  backdrop-filter: none;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 0;
  color: #fff;
  font-weight: 500;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: none;
  width: 100%;
  font-family: 'Raleway', sans-serif;
}

.glass-cta-button:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.6);
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(255, 255, 255, 0.1);
}

.glass-cta-button:active {
  transform: translateY(0);
  background: rgba(255, 255, 255, 0.08);
}

.button-text {
  position: relative;
  z-index: 2;
}

.button-glow {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  transition: left 0.5s ease;
  pointer-events: none;
}

.glass-cta-button:hover .button-glow {
  left: 100%;
}

/* Responsive */
@media (max-width: 768px) {
  .glass-cta-button {
    padding: 0.75rem 1.5rem;
    font-size: 0.7rem;
    letter-spacing: 1.5px;
  }
}
/* ==================== CART BUBBLE STYLES ==================== */
.cart-bubble {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 60px;
  height: 60px;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(15px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 9999;
  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  animation: pulse 2s infinite;
}
@keyframes pulse {0%,100%{transform:scale(1);}50%{transform:scale(1.05);}}
.cart-bubble:hover {transform:scale(1.15);box-shadow:0 15px 40px rgba(0,0,0,0.5);}
.cart-bubble svg, .cart-bubble img{width:36px;height:36px;stroke:#fff;stroke-width:2;fill:none;object-fit:contain;}
.cart-bubble-count{
  position:absolute;
  top:-6px; right:-6px;
  min-width:24px;height:24px;
  border-radius:50%;
  background:#fff;color:#000;
  display:none;align-items:center;justify-content:center;
  font-weight:700;font-size:0.75rem;
  border:1px solid #000;
}
.cart-bubble-count.show{display:flex;}

/* CART SIDEBAR */
.cart-sidebar {
  position: fixed; right:-450px; top:0;
  width:450px;height:100vh;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(15px);
  box-shadow: -5px 0 30px rgba(0,0,0,0.3);
  display:flex;flex-direction:column;z-index:10000;
  transition: right 0.4s cubic-bezier(0.165,0.84,0.44,1);
  overflow: hidden;
}
.cart-sidebar.open {right:0;}

.cart-header {
  padding:1.5rem;
  display:flex;justify-content:space-between;align-items:center;
  border-bottom:1px solid #fff;color:#fff;
  flex-shrink: 0;
}
.cart-header h3 {
  color: #fff;
  margin: 0;
}
.cart-close {
  width:36px;height:36px;
  border:none;background:transparent;color:#fff;
  font-size:1.5rem;font-weight:700;
  cursor:pointer;
  transition: opacity 0.2s;
  outline:none;
}
.cart-close:hover {opacity:0.7;}
.cart-close:focus {outline:none;}
.cart-close:hover {opacity:0.7;}

.cart-items {
  flex:1;
  padding:1rem;
  overflow-y:auto;
  overflow-x: hidden;
}
.cart-items::-webkit-scrollbar {width:8px;}
.cart-items::-webkit-scrollbar-thumb {background:rgba(255,255,255,0.3);border-radius:4px;}
.cart-items::-webkit-scrollbar-track {background:transparent;}

.cart-empty {
  text-align: center;
  color: #fff;
  padding: 3rem 1rem;
}
.cart-empty p {
  color: #fff;
  margin: 0;
}
.cart-item {display:flex;gap:1rem;margin-bottom:1.5rem;position:relative;align-items:center;}
.cart-item-image-wrapper{width:80px;height:80px;flex-shrink:0;overflow:hidden;border:1px solid #fff;}
.cart-item-image{width:100%;height:100%;object-fit:cover;}
.cart-item-details{flex:1;display:flex;flex-direction:column;min-width:0;}
.cart-item-title{font-weight:700;color:#fff;word-wrap:break-word;}
.cart-item-price{color:#ccc;margin:0.25rem 0;}
.cart-item-controls{display:flex;align-items:center;gap:0.5rem;margin-top:auto;}
.cart-item-quantity{display:flex;align-items:center;gap:0.5rem;border:1px solid #fff;padding:0.25rem;border-radius:8px;}
.qty-btn{
  width:28px;height:28px;
  border:none;background:#fff;color:#000;
  font-weight:700;cursor:pointer;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:transform 0.2s, background 0.2s;
  flex-shrink: 0;
  outline:none;
}
.qty-btn:focus{outline:none;}
.qty-btn:hover{transform:scale(1.1);background:#f0f0f0;}
.qty-btn:active{transform:scale(0.95);}
.qty-display{min-width:24px;text-align:center;color:#fff;font-weight:700;}
.remove-btn{
  width:28px;height:28px;
  border:none;background:transparent;
  color:#fff;font-weight:700;cursor:pointer;
  transition:color 0.2s, transform 0.2s;
  flex-shrink: 0;
  outline:none;
}
.remove-btn:focus{outline:none;}
.remove-btn:hover{color:#ccc;transform:scale(1.1);}
.remove-btn:active{transform:scale(0.95);}

.cart-footer{
  padding:1.5rem;
  border-top:1px solid #fff;
  flex-shrink: 0;
}
.cart-subtotal,.cart-total{display:flex;justify-content:space-between;color:#fff;margin-bottom:0.5rem;}
.checkout-btn{
  width:100%;
  padding:0.75rem;
  background:#fff;
  color:#000;
  border:none;
  font-weight:700;
  text-transform:uppercase;
  cursor:pointer;
  transition:background 0.2s, transform 0.2s;
  border-radius:12px;
  font-size:1rem;
}
.checkout-btn:hover{background:#f0f0f0;transform:translateY(-2px);}
.checkout-btn:active{transform:translateY(0);}
.checkout-btn:disabled{opacity:0.5;cursor:not-allowed;}

/* Overlay */
.cart-overlay {
  position:fixed;top:0;left:0;width:100%;height:100%;
  background:rgba(0,0,0,0.4);z-index:9998;
  opacity:0;visibility:hidden;
  transition:opacity 0.3s, visibility 0.3s;
  backdrop-filter:blur(5px);
}
.cart-overlay.show {opacity:1;visibility:visible;}

/* Notification */
.cart-notification {
  position:fixed;top:20px;right:20px;
  background:#fff;color:#000;
  padding:1rem 1.5rem;
  border-radius:8px;
  box-shadow:0 4px 20px rgba(0,0,0,0.3);
  z-index:10001;
  animation:slideIn 0.3s ease;
}
@keyframes slideIn {from{transform:translateX(400px);opacity:0;}to{transform:translateX(0);opacity:1;}}

@media(max-width:768px){
  .cart-sidebar{width:100%;right:-100%;}
  .cart-bubble{width:50px;height:50px;bottom:20px;right:20px;}
}
</style>

<script>
// CONFIG
const SHOPIFY_CONFIG={
  storeDomain:'adelaidedistilleryco.myshopify.com',
  storefrontAccessToken:'8a59cc23d6e61598b80b8bb7344a7d78',
  apiVersion:'2024-10'
};

// CART CLASS
class ShopifyCartBubble {
  constructor(){
    this.items=JSON.parse(localStorage.getItem('shopify_cart_bubble')||'[]');
    this.init();
  }
  
  init(){
    this.createUI();
    this.updateCartDisplay();
  }
  
  saveCart(){
    localStorage.setItem('shopify_cart_bubble',JSON.stringify(this.items));
    this.updateCartDisplay();
  }
  
  addItem(product,qty=1){
    const existing=this.items.find(i=>i.variantId===product.variantId);
    if(existing){
      existing.quantity+=qty;
    }else{
      this.items.push({...product,quantity:qty});
    }
    this.saveCart();
    this.showNotification(`${product.title} added to cart`);
  }
  
  removeItem(variantId){
    this.items=this.items.filter(i=>i.variantId!==variantId);
    this.saveCart();
  }
  
  updateQuantity(variantId,qty){
    if(qty<=0){
      this.removeItem(variantId);
      return;
    }
    const item=this.items.find(i=>i.variantId===variantId);
    if(item){
      item.quantity=qty;
      this.saveCart();
    }
  }
  
  getTotal(){
    return this.items.reduce((sum,i)=>sum+i.price*i.quantity,0);
  }
  
  getTotalItems(){
    return this.items.reduce((sum,i)=>sum+i.quantity,0);
  }
  
  updateCartDisplay(){
    this.updateBubbleCount();
    this.renderCartItems();
  }
  
  updateBubbleCount(){
    const c=document.getElementById('cart-bubble-count');
    if(c){
      const t=this.getTotalItems();
      c.textContent=t;
      t>0?c.classList.add('show'):c.classList.remove('show');
    }
  }
  
  createUI(){
    const container=document.getElementById('shopify-cart-widget');
    
    const overlay=document.createElement('div');
    overlay.className='cart-overlay';
    overlay.id='cart-overlay';
    overlay.onclick=()=>this.toggleCart();
    
    const bubble=document.createElement('div');
    bubble.className='cart-bubble';
    bubble.id='cart-bubble';
    bubble.onclick=()=>this.toggleCart();
   bubble.innerHTML=`<img src="brandmark.svg" alt="Cart" style="width:36px;height:36px;object-fit:contain;"><span id="cart-bubble-count" class="cart-bubble-count">0</span>`;
    
    const sidebar=document.createElement('div');
    sidebar.className='cart-sidebar';
    sidebar.id='cart-sidebar';
    sidebar.innerHTML=`
      <div class="cart-header">
        <h3>Your Cart</h3>
        <button class="cart-close" id="cart-close">×</button>
      </div>
      <div class="cart-items" id="cart-items"></div>
      <div class="cart-footer">
        <div class="cart-subtotal">
          <span>Subtotal:</span>
          <span id="cart-subtotal">$0.00</span>
        </div>
        <div class="cart-total">
          <span>Total:</span>
          <span id="cart-total">$0.00</span>
        </div>
        <button class="checkout-btn" id="checkout-btn">Checkout</button>
      </div>
    `;
    
    container.appendChild(overlay);
    container.appendChild(bubble);
    container.appendChild(sidebar);
    
    document.getElementById('cart-close').onclick=()=>this.toggleCart();
    document.getElementById('checkout-btn').onclick=()=>this.checkout();
    
    this.renderCartItems();
  }
  
  toggleCart(){
    document.getElementById('cart-sidebar').classList.toggle('open');
    document.getElementById('cart-overlay').classList.toggle('show');
  }
  
  renderCartItems(){
    const c=document.getElementById('cart-items');
    const subtotal=document.getElementById('cart-subtotal');
    const total=document.getElementById('cart-total');
    
    if(this.items.length===0){
      c.innerHTML=`<div class="cart-empty"><p>Your cart is empty</p></div>`;
      subtotal.textContent='$0.00';
      total.textContent='$0.00';
      return;
    }
    
    c.innerHTML=this.items.map(i=>`
      <div class="cart-item">
        <div class="cart-item-image-wrapper">
          <img src="${i.image}" class="cart-item-image" alt="${i.title}">
        </div>
        <div class="cart-item-details">
          <div class="cart-item-title">${i.title}</div>
          <div class="cart-item-price">$${i.price.toFixed(2)}</div>
          <div class="cart-item-controls">
            <div class="cart-item-quantity">
              <button class="qty-btn" onclick="cartBubble.updateQuantity('${i.variantId}',${i.quantity-1})">−</button>
              <span class="qty-display">${i.quantity}</span>
              <button class="qty-btn" onclick="cartBubble.updateQuantity('${i.variantId}',${i.quantity+1})">+</button>
            </div>
            <button class="remove-btn" onclick="cartBubble.removeItem('${i.variantId}')">×</button>
          </div>
        </div>
      </div>
    `).join('');
    
    const totalAmount=this.getTotal();
    subtotal.textContent=`$${totalAmount.toFixed(2)}`;
    total.textContent=`$${totalAmount.toFixed(2)}`;
  }
  
  async checkout(){
    if(this.items.length===0){
      alert('Your cart is empty');
      return;
    }
    
    const btn=document.getElementById('checkout-btn');
    btn.disabled=true;
    btn.textContent='Loading...';
    
    try{
      const checkoutUrl=await this.createCart();
      if(checkoutUrl){
        window.location.href=checkoutUrl;
      }else{
        alert('Error creating checkout. Please try again.');
        btn.disabled=false;
        btn.textContent='Checkout';
      }
    }catch(err){
      console.error('Checkout error:',err);
      alert('Error creating checkout. Please try again.');
      btn.disabled=false;
      btn.textContent='Checkout';
    }
  }
  
  async createCart(){
    const lines=this.items.map(item=>({
      merchandiseId:item.variantId,
      quantity:item.quantity
    }));
    
    const mutation=`
      mutation cartCreate($input: CartInput!) {
        cartCreate(input: $input) {
          cart {
            id
            checkoutUrl
          }
          userErrors {
            field
            message
          }
        }
      }
    `;
    
    const variables={
      input:{
        lines:lines
      }
    };
    
    const response=await fetch(`https://${SHOPIFY_CONFIG.storeDomain}/api/${SHOPIFY_CONFIG.apiVersion}/graphql.json`,{
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'X-Shopify-Storefront-Access-Token':SHOPIFY_CONFIG.storefrontAccessToken
      },
      body:JSON.stringify({query:mutation,variables:variables})
    });
    
    const result=await response.json();
    
    if(result.data.cartCreate.userErrors.length>0){
      console.error('Cart errors:',result.data.cartCreate.userErrors);
      return null;
    }
    
    return result.data.cartCreate.cart.checkoutUrl;
  }
  
  showNotification(msg){
    const n=document.createElement('div');
    n.className='cart-notification';
    n.textContent=msg;
    document.body.appendChild(n);
    setTimeout(()=>{
      n.remove();
    },2000);
  }
}

// INIT
let cartBubble;
document.addEventListener('DOMContentLoaded',()=>{
  cartBubble=new ShopifyCartBubble();
  window.shopifyCartBubble=cartBubble;
});

// SMART BUTTON EXAMPLE
// Product cache with session storage (clears on browser close/reload)
const productCache = {
  data: {},
  isProcessing: {},
  
  get(name) {
    return this.data[name.toLowerCase()];
  },
  
  set(name, product) {
    this.data[name.toLowerCase()] = product;
  },
  
  isLoading(name) {
    return this.isProcessing[name.toLowerCase()] || false;
  },
  
  setLoading(name, status) {
    this.isProcessing[name.toLowerCase()] = status;
  }
};

async function fetchProductByNameInsensitive(name){
  const lowerName = name.toLowerCase();
  
  // Check cache first
  const cached = productCache.get(lowerName);
  if (cached) {
    console.log('Using cached product:', name);
    return cached;
  }
  
  // Prevent duplicate API calls
  if (productCache.isLoading(lowerName)) {
    console.log('Already fetching:', name);
    return null;
  }
  
  productCache.setLoading(lowerName, true);
  
  try {
    const q=`query getProducts($query:String!){products(first:50,query:$query){edges{node{id title variants(first:1){edges{node{id price:priceV2{amount} image{url}}}}}}}}`;
    const res=await fetch(`https://${SHOPIFY_CONFIG.storeDomain}/api/${SHOPIFY_CONFIG.apiVersion}/graphql.json`,{
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "X-Shopify-Storefront-Access-Token":SHOPIFY_CONFIG.storefrontAccessToken
      },
      body:JSON.stringify({query:q,variables:{query:`title:*${lowerName}*`}})
    });
    
    const data=await res.json();
    
    if(!data.data.products.edges.length){
      alert("Product not found: "+name);
      productCache.setLoading(lowerName, false);
      return null;
    }
    
    const match=data.data.products.edges.find(p=>p.node.title.toLowerCase()===lowerName)||data.data.products.edges[0];
    const product=match.node;
    const variant=product.variants.edges[0].node;
    
    const productData = {
      id:product.id,
      title:product.title,
      price:parseFloat(variant.price.amount),
      image:variant.image?variant.image.url:"",
      variantId:variant.id
    };
    
    // Cache the result
    productCache.set(lowerName, productData);
    productCache.setLoading(lowerName, false);
    
    return productData;
  } catch (error) {
    console.error('Error fetching product:', error);
    productCache.setLoading(lowerName, false);
    alert('Error loading product. Please try again.');
    return null;
  }
}

document.addEventListener("click",async e=>{
  if(!e.target.matches(".smart-add") && !e.target.closest(".smart-add"))return;
  
  const button = e.target.matches(".smart-add") ? e.target : e.target.closest(".smart-add");
  const name = button.dataset.productName;
  
  if(!name)return;
  
  // Disable button during processing
  button.disabled = true;
  const originalText = button.innerHTML;
  button.innerHTML = '<span class="button-text">Adding...</span>';
  
  const p = await fetchProductByNameInsensitive(name);
  
  if(p){
    window.shopifyCartBubble.addItem(p,1);
  }
  
  // Re-enable button
  button.disabled = false;
  button.innerHTML = originalText;
});


</script>

