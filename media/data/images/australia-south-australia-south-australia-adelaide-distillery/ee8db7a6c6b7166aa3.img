<script>
(function() {
  'use strict';
  
  const NewsletterSidebar = {
    hasAppeared: false,
    
    init() {
      // Wait for preloader to finish, then setup scroll detection
      this.waitForPreloader();
    },
    
    waitForPreloader() {
      const checkPreloader = () => {
        const preloader = document.querySelector('[style*="z-index: 99"], [style*="z-index:99"], .preloader, #preloader');
        
        // Check if preloader exists and is hidden
        if (!preloader || 
            window.getComputedStyle(preloader).display === 'none' || 
            window.getComputedStyle(preloader).opacity === '0' ||
            preloader.style.display === 'none') {
          // Preloader is done, setup scroll detection
          setTimeout(() => {
            this.setupScrollDetection();
          }, 500);
        } else {
          // Check again in 100ms
          setTimeout(checkPreloader, 100);
        }
      };
      
      // Start checking after DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', checkPreloader);
      } else {
        checkPreloader();
      }
    },
    
    setupScrollDetection() {
      const productGrid = document.querySelector('.grid.grid_fluid-3.js-grid');
      const tab = document.getElementById('newsletter-left-tab');
      
      if (!productGrid || !tab) return;
      
      const checkScroll = () => {
        // If tab has already appeared, keep it visible
        if (this.hasAppeared) {
          return;
        }
        
        const rect = productGrid.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        // Show tab when product grid enters viewport
        if (rect.top < windowHeight && rect.bottom > 0) {
          tab.classList.add('visible');
          tab.classList.remove('hidden');
          this.hasAppeared = true;
          
          // Remove scroll listener since we don't need it anymore
          window.removeEventListener('scroll', checkScroll);
        }
      };
      
      // Check on scroll
      window.addEventListener('scroll', checkScroll, { passive: true });
      
      // Initial check
      checkScroll();
    }
  };
  
  NewsletterSidebar.init();
})();
</script>

  </body>
