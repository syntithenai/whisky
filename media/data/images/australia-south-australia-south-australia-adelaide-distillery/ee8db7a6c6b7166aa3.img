<div class="container-fluid container_px-xs-0">

<style>
  /* MATCH HEIGHT ON BOTH SIDES */
  .contact-row {
    display: flex;
    align-items: stretch;
  }

  @media (max-width: 991px) {
    .contact-row {
      flex-direction: column-reverse;
    }
  }

  /* make all left text white */
  .contact-left * {
    color: #fff !important;
  }

  /* LEFT COLUMN FULL HEIGHT, SPLIT INTO TWO BOXES */
  .contact-left {
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  /* TOP BOX — CENTER TEXT PERFECTLY */
  .left-top-box {
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(0, 0, 0, 0.75);
  }

  /* BOTTOM BOX — IMAGE FIT (COVER) */
  .left-bottom-box {
    flex: 1;
    background-image: url('img/images/cheers.jpg');
    background-size: cover;        /* makes image fit fully */
    background-position: center;   /* centers image */
    background-repeat: no-repeat;
    position: relative;
  }

  /* dark overlay */
  .left-bottom-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1;
  }

  .left-bottom-inner {
    position: relative;
    z-index: 2;
    height: 100%;
  }

  /* FORM STYLING */
  .form-contact_paddings {
    padding: 3rem 2rem;
  }

  @media (max-width: 991px) {
    .form-contact_paddings {
      padding: 2rem 1.5rem;
    }
  }
</style>


<section class="section section-contacts section-properties section-content">
  <div class="container-fluid no-gutters">
    <div class="row no-gutters contact-row">

      <!-- LEFT COLUMN -->
      <div class="col-lg-5 col-12 d-flex flex-column contact-left">

        <!-- CENTERED TEXT BOX -->
        <div class="left-top-box">
          <div class="section-properties__item my-2">
            <div class="figure-info">
              <div class="figure-info__option small-caps">Get in contact</div>
              <div class="figure-info__value paragraph">
                <a href="mailto:hello@adelaidedistillery.com.au">hello@adelaidedistillery.com.au</a><br>
                
              </div>
            </div>
          </div>

          <div class="section-properties__item my-2">
            <div class="figure-info">
              <div class="figure-info__option small-caps">Social Media</div>
              <ul class="social" style="list-style:none;padding:0;margin:0;display:flex;gap:10px;justify-content:center;">
                <li><a class="fa fa-facebook-f" href="https://www.facebook.com/adelaidedistillery/"></a></li>
                
                <li><a class="fa fa-instagram" href="https://www.instagram.com/adelaidedistillery/?hl=en"></a></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- IMAGE BOX -->
        <div class="left-bottom-box">
          <div class="left-bottom-inner"></div>
        </div>

      </div>

      <!-- RIGHT COLUMN — FORM -->
      <div class="col-lg-7 col-12 bg-light-1">
        <div class="h-100">
          <form id="contactForm" class="form form-contact form-contact_paddings" action="https://api.web3forms.com/submit" method="POST">

            <!-- Web3Forms Access Key -->
            <input type="hidden" name="access_key" value="8a7b81d9-eb06-4607-beb6-a1748220bd6e">
            
            <!-- Optional: Redirect after submission -->
            <input type="hidden" name="redirect" value="https://yourdomain.com/thank-you.html">
            
            <!-- Optional: Custom subject line -->
            <input type="hidden" name="subject" value="New Contact Form Submission from Adelaide Distillery">
            
            <!-- Optional: From name -->
            <input type="hidden" name="from_name" value="Adelaide Distillery Contact Form">

            <div class="row form__row">
              <div class="col form__col">
                <h3 class="h3 mt-0 mb-0">Send Message</h3>
              </div>
            </div>

            <div class="row form__row">
              <div class="col form__col">
                <label class="input-float js-input-float">
                  <input class="input-float__input" type="text" name="name" required>
                  <span class="input-float__label">Your Name</span>
                </label>
              </div>
            </div>

            <div class="row form__row">
              <div class="col form__col">
                <label class="input-float js-input-float">
                  <input class="input-float__input" type="email" name="email" required>
                  <span class="input-float__label">Your E-mail</span>
                </label>
              </div>
            </div>

            <div class="row form__row">
              <div class="col form__col">
                <label class="input-float js-input-float">
                  <textarea class="input-float__input input-float__input_textarea" name="message" required></textarea>
                  <span class="input-float__label">Your Message</span>
                </label>
              </div>
            </div>

            <!-- Success/Error Messages -->
            <div class="row form__row">
              <div class="col form__col">
                <div id="formMessage" style="display:none; padding:10px; margin-bottom:15px; border-radius:4px;"></div>
              </div>
            </div>

            <div class="row form__row">
              <div class="col form__col form__col_submit">
                <button type="submit" class="button button_solid button_black button_fullwidth">
                  <span class="button__label-hover">Send Message</span>
                </button>
              </div>
            </div>

          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const form = e.target;
    const formData = new FormData(form);
    const submitButton = form.querySelector('button[type="submit"]');
    const messageDiv = document.getElementById('formMessage');
    
    // Disable button during submission
    submitButton.disabled = true;
    submitButton.querySelector('.button__label-hover').textContent = 'Sending...';
    
    try {
        const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
            messageDiv.style.display = 'block';
            messageDiv.style.backgroundColor = '#d4edda';
            messageDiv.style.color = '#155724';
            messageDiv.style.border = '1px solid #c3e6cb';
            messageDiv.textContent = 'Thank you! Your message has been sent successfully.';
            form.reset();
            
            // Remove float labels
            document.querySelectorAll('.input-float').forEach(float => {
                float.classList.remove('input-float--active');
            });
            
        } else {
            throw new Error(data.message || 'Something went wrong');
        }
        
    } catch (error) {
        messageDiv.style.display = 'block';
        messageDiv.style.backgroundColor = '#f8d7da';
        messageDiv.style.color = '#721c24';
        messageDiv.style.border = '1px solid #f5c6cb';
        messageDiv.textContent = 'Oops! There was a problem sending your message. Please try again.';
    } finally {
        // Re-enable button
        submitButton.disabled = false;
        submitButton.querySelector('.button__label-hover').textContent = 'Send Message';
    }
});
</script>
</div>

